model StatementUpload {
  id String @id @default(uuid())

  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  mpesaAccountId String?
  mpesaAccount   MpesaAccount? @relation(fields: [mpesaAccountId], references: [id])

  statementType String
  fileName      String
  fileUrl       String

  periodStart DateTime
  periodEnd   DateTime

  openingBalance Decimal @db.Decimal(15, 2)
  closingBalance Decimal @db.Decimal(15, 2)

  totalTransactions Int
  matchedCount      Int @default(0)
  unmatchedCount    Int @default(0)

  status ReconciliationStatus @default(UPLOADED)

  reconciledById String?
  reconciledAt   DateTime?
  completedById  String?
  completedAt    DateTime?
  uploadedById   String?

  notes String?

  items ReconciliationItem[]
  matches ReconciliationMatch[]

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([bankAccountId])
  @@index([mpesaAccountId])
  @@index([status])
  @@map("statement_uploads")
}

model ReconciliationItem {
  id                String @id @default(uuid())
  statementUploadId String

  transactionDate DateTime
  valueDate       DateTime?
  description     String
  reference       String?
  amount          Decimal   @db.Decimal(15, 2)
  isDebit         Boolean
  runningBalance  Decimal?  @db.Decimal(15, 2)

  matchedPaymentId            String?
  matchedFinanceTransactionId String?
  matchedFinanceTransaction   FinanceTransaction? @relation(fields: [matchedFinanceTransactionId], references: [id])
  matchedJournalEntryId       String?
  matchedExpenseId            String?
  matchedRemittanceId         String?
  matchedCommissionReceiptId  String?
  matchStatus                 MatchStatus         @default(UNMATCHED)
  matchConfidence             Decimal?            @db.Decimal(3, 2)
  matchedAt                   DateTime?
  matchedById                 String?

  notes String?

  statementUpload StatementUpload @relation(fields: [statementUploadId], references: [id], onDelete: Cascade)
  matches         ReconciliationMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statementUploadId])
  @@index([matchedFinanceTransactionId])
  @@index([matchStatus])
  @@index([transactionDate])
  @@map("reconciliation_items")
}

model ReconciliationMatch {
  id String @id @default(uuid())

  statementUploadId String
  statementUpload   StatementUpload @relation(fields: [statementUploadId], references: [id], onDelete: Cascade)

  reconciliationItemId String
  reconciliationItem   ReconciliationItem @relation(fields: [reconciliationItemId], references: [id], onDelete: Cascade)

  financeTransactionId String
  financeTransaction   FinanceTransaction @relation(fields: [financeTransactionId], references: [id], onDelete: Cascade)

  matchedAmount Decimal @db.Decimal(15, 2)
  matchConfidence Decimal? @db.Decimal(3, 2)
  matchLevel      String?
  isAuto          Boolean @default(false)
  notes           String?
  createdById     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reconciliationItemId, financeTransactionId])
  @@index([statementUploadId])
  @@index([reconciliationItemId])
  @@index([financeTransactionId])
  @@map("reconciliation_matches")
}

