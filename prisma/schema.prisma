  documentsDueAt       DateTime?
  submissionDueAt      DateTime?
  insurerFollowUpDueAt DateTime?
  resolutionDueAt      DateTime?

  submittedToInsurerAt DateTime?
  assessedAt           DateTime?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  settledAt            DateTime?
  closedAt             DateTime?
  withdrawnAt          DateTime?
  voidedAt             DateTime?
  voidReason           String?

  notes String?

  activities      ClaimActivity[]
  documents       ClaimDocument[]
  queries         ClaimQuery[]
  assessments     ClaimAssessment[]
  settlements     ClaimSettlement[]
