  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([claimId])
  @@index([requirementId])
  @@index([status])
  @@map("claim_documents")
}

model ClaimDocumentRequirement {
  id String @id @default(uuid())

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

