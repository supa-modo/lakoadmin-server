// ─────────────────────────────────────────────────────────

model Policy {
  id                  String  @id @default(uuid())
  policyNumber        String  @unique
  insurerPolicyNumber String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  insurerId String
  insurer   Insurer @relation(fields: [insurerId], references: [id])

  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id])

  onboardingCaseId String?
  onboardingCase   OnboardingCase? @relation(fields: [onboardingCaseId], references: [id], onDelete: SetNull)

  sourceLeadId String?
  sourceLead   Lead?   @relation("LeadSourcedPolicies", fields: [sourceLeadId], references: [id], onDelete: SetNull)

  startDate DateTime
  endDate   DateTime

  sumInsured Decimal? @db.Decimal(15, 2)

  basePremium  Decimal @db.Decimal(15, 2)
  trainingLevy Decimal @default(0) @db.Decimal(15, 2)
  pcifLevy     Decimal @default(0) @db.Decimal(15, 2)
  stampDuty    Decimal @default(0) @db.Decimal(15, 2)
  policyFee    Decimal @default(0) @db.Decimal(15, 2)
  totalPremium Decimal @db.Decimal(15, 2)

  paymentFrequency  PaymentFrequency @default(ANNUAL)
  paidAmount        Decimal          @default(0) @db.Decimal(15, 2)
  outstandingAmount Decimal          @db.Decimal(15, 2)

  premiumCollectionMode     PremiumCollectionMode      @default(BROKER_COLLECTED)
  premiumPaidTo             PremiumPaidTo              @default(BROKER)
  brokerCollectedAmount     Decimal                    @default(0) @db.Decimal(15, 2)
  directToInsurerAmount     Decimal                    @default(0) @db.Decimal(15, 2)
  totalPremiumAmount        Decimal                    @default(0) @db.Decimal(15, 2)
  outstandingPremiumAmount  Decimal                    @default(0) @db.Decimal(15, 2)
  paymentVerificationStatus DirectInsurerPaymentStatus @default(UNVERIFIED)

  commissionSettlementMode   CommissionSettlementMode @default(PAID_BY_INSURER)
  insurerCommissionStatus    InsurerCommissionStatus  @default(NOT_DUE)
  commissionReceivableAmount Decimal                  @default(0) @db.Decimal(15, 2)
  commissionReceivedAmount   Decimal                  @default(0) @db.Decimal(15, 2)

  status             PolicyStatus       @default(DRAFT)
  underwritingStatus UnderwritingStatus @default(PENDING)

  renewedFromId String? @unique
  renewedFrom   Policy? @relation("PolicyRenewal", fields: [renewedFromId], references: [id])
  renewedTo     Policy? @relation("PolicyRenewal")

  cancellationDate   DateTime?
  cancellationReason String?

  suspensionDate   DateTime?
  suspensionReason String?
  reinstatedDate   DateTime?

  notes String?

  members                PolicyMember[]
  endorsements           PolicyEndorsement[]
  events                 PolicyEvent[]
  documents              PolicyDocument[]
  claims                 Claim[]
  paymentAllocations     PaymentAllocation[]
  directInsurerPayments  DirectInsurerPayment[]
  commissionEntries      CommissionEntry[]
  tasks                  Task[]                  @relation("PolicyTasks")
  invoiceLines           InvoiceLine[]
  journalEntries         JournalEntry[]
  insurerRemittanceLines InsurerRemittanceLine[]
  messageLogs            MessageLog[]

  createdById String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([clientId])
  @@index([insurerId])
  @@index([productId])
  @@index([agentId])
  @@index([onboardingCaseId])
  @@index([sourceLeadId])
  @@index([status])
  @@index([endDate])
  @@index([policyNumber])
  @@index([premiumCollectionMode])
  @@index([insurerCommissionStatus])
  @@index([status, endDate])
  @@map("policies")
}

model PolicyMember {
  id       String @id @default(uuid())
