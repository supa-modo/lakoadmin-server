// ─────────────────────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────────────────────

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  avatarUrl String?

  isActive          Boolean   @default(true)
  failedLogins      Int       @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  passwordChangedAt DateTime?

  // Password reset
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // Refresh tokens (stored as JSON array of token hashes)
  refreshTokens String[]

  // Relations
  roles UserRole[]
  agent Agent?

  // Audit relations (as actor)
  auditLogs      AuditLog[]
  createdLeads   Lead[]         @relation("LeadCreator")
  assignedLeads  Lead[]         @relation("LeadAssignment")
  managedClients Client[]       @relation("ClientManager")
  ownedClaims    Claim[]        @relation("ClaimOwner")
  assignedTasks  Task[]         @relation("TaskAssignment")
  createdTasks   Task[]         @relation("TaskCreator")
  taskActivities TaskActivity[]
  leadActivities LeadActivity[]
  notifications  Notification[]
  createdMessageTemplates MessageTemplate[]         @relation("MessageTemplateCreator")
  updatedMessageTemplates MessageTemplate[]         @relation("MessageTemplateUpdater")
  createdMessageLogs      MessageLog[]              @relation("MessageLogCreator")
  userMessageLogs         MessageLog[]              @relation("MessageLogUser")
  messageRecipients       MessageRecipient[]
  createdCampaigns        CommunicationCampaign[]   @relation("CampaignCreator")
  communicationPreferences CommunicationPreference[]
  createdAutomationRules  AutomationRule[]          @relation("AutomationRuleCreator")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  displayName String
  description String?
  isSystem    Boolean @default(false)

  permissions RolePermission[]
  users       UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique
  module      String
  action      String
  description String?

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  assignedBy String?

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String
  entity   String
  entityId String?

  before Json?
  after  Json?

  ipAddress String?
  userAgent String?
  requestId String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────
// CRM MODELS
// ─────────────────────────────────────────────────────────

model Lead {
  id String @id @default(uuid())

  name        String
  email       String?
  phone       String?
  companyName String?

  leadType ClientType @default(INDIVIDUAL)

  source       String?
  sourceDetail String?
  referrerId   String?

  status   LeadStatus   @default(NEW)
  priority LeadPriority @default(WARM)

  productsOfInterest String[]
  expectedPremium    Decimal? @db.Decimal(15, 2)

  assignedToId String?
  assignedTo   User?   @relation("LeadAssignment", fields: [assignedToId], references: [id], onDelete: SetNull)

  convertedToClientId String?   @unique
  convertedToClient   Client?   @relation(fields: [convertedToClientId], references: [id])
  convertedAt         DateTime?

  lostReason String?
  lostAt     DateTime?

  notes        String?
  nextFollowUp DateTime?

  activities      LeadActivity[]
  tasks           Task[]           @relation("LeadTasks")
  onboardingCases OnboardingCase[] @relation("LeadOnboardingCases")
  sourcedPolicies Policy[]         @relation("LeadSourcedPolicies")

  createdById String?
  createdBy   User?   @relation("LeadCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([assignedToId])
  @@index([source])
  @@index([createdAt])
  @@map("leads")
}

model LeadActivity {
  id     String @id @default(uuid())
  leadId String

  type        String
  description String
  metadata    Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
  @@index([userId])
  @@map("lead_activities")
}

model Client {
  id           String     @id @default(uuid())
  clientNumber String     @unique
  type         ClientType

  firstName      String?
  lastName       String?
  dateOfBirth    DateTime?
  gender         String?
  nationalId     String?
  passportNumber String?

  companyName        String?
  registrationNumber String?
  incorporationDate  DateTime?
  tradingName        String?

  kraPin    String?
  vatNumber String?

  email          String?
  phone          String?
  alternatePhone String?
  website        String?

  physicalAddress String?
  postalAddress   String?
  county          String?
  country         String? @default("Kenya")

  industry       String?
  employeeCount  String?
  annualTurnover String?

  relationshipManagerId String?
  relationshipManager   User?   @relation("ClientManager", fields: [relationshipManagerId], references: [id], onDelete: SetNull)

  preferredChannel  String?
  preferredLanguage String? @default("en")
  marketingOptIn    Boolean @default(false)
  smsOptIn          Boolean @default(true)
  emailOptIn        Boolean @default(true)

  riskCategory String?

  contacts              ClientContact[]
  policies              Policy[]
  claims                Claim[]
  payments              Payment[]
  directInsurerPayments DirectInsurerPayment[]
  invoices              Invoice[]
  tasks                 Task[]                 @relation("ClientTasks")
  onboardingCases       OnboardingCase[]
  lead                  Lead?
  documents             Document[]             @relation("ClientDocuments")
  messageLogs           MessageLog[]
  messageRecipients     MessageRecipient[]
  communicationPreferences CommunicationPreference[]

  createdById String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([type])
  @@index([relationshipManagerId])
  @@index([kraPin])
  @@index([email])
  @@index([phone])
  @@map("clients")
}

model ClientContact {
  id       String @id @default(uuid())
  clientId String

  name       String
  title      String?
  department String?
  email      String?
  phone      String?

  role         String?
  isPrimary    Boolean @default(false)
  canAuthorize Boolean @default(false)

  notes String?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messageRecipients MessageRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("client_contacts")
}

model OnboardingCase {
  id         String @id @default(uuid())
  caseNumber String @unique

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  leadId String?
  lead   Lead?   @relation("LeadOnboardingCases", fields: [leadId], references: [id], onDelete: SetNull)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  insurerId String?
  insurer   Insurer? @relation(fields: [insurerId], references: [id], onDelete: SetNull)

  clientType ClientType
  status     OnboardingStatus @default(DRAFT)

  premiumEstimate Decimal? @db.Decimal(15, 2)
  riskDetails     Json?
  memberData      Json?

  reviewerId  String?
  reviewNotes String?

  submittedAt DateTime?
  reviewedAt  DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?

  rejectionReason String?

  documents OnboardingDocument[]
  policies  Policy[]
  tasks     Task[]               @relation("OnboardingCaseTasks")
  messageLogs MessageLog[]

  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([leadId])
  @@index([productId])
  @@index([insurerId])
  @@index([status])
  @@map("onboarding_cases")
}

model OnboardingDocument {
  id               String @id @default(uuid())
  onboardingCaseId String

  documentType String
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String

  status DocumentVerificationStatus @default(PENDING)

  verifiedById    String?
  verifiedAt      DateTime?
  rejectionReason String?

  expiryDate DateTime?

  onboardingCase OnboardingCase @relation(fields: [onboardingCaseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([onboardingCaseId])
  @@index([status])
  @@map("onboarding_documents")
}

model Task {
  id String @id @default(uuid())

  title       String
  description String?
  category    String?
  dueDate     DateTime?
  priority    TaskPriority @default(NORMAL)
  status      TaskStatus   @default(PENDING)

  activities TaskActivity[]

  leadId String?
  lead   Lead?   @relation("LeadTasks", fields: [leadId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation("ClientTasks", fields: [clientId], references: [id], onDelete: Cascade)

  onboardingCaseId String?
  onboardingCase   OnboardingCase? @relation("OnboardingCaseTasks", fields: [onboardingCaseId], references: [id], onDelete: Cascade)

  policyId String?
  policy   Policy? @relation("PolicyTasks", fields: [policyId], references: [id], onDelete: Cascade)

  claimId String?
  claim   Claim?  @relation("ClaimTasks", fields: [claimId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignment", fields: [assignedToId], references: [id], onDelete: SetNull)

  completedAt   DateTime?
  completedById String?

  isRecurring    Boolean @default(false)
  recurrenceRule String?

  createdById String?
  createdBy   User?   @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  messageLogs MessageLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
  @@index([leadId])
  @@index([clientId])
  @@index([onboardingCaseId])
  @@index([policyId])
  @@index([claimId])
  @@map("tasks")
}

model TaskActivity {
  id     String @id @default(uuid())
  taskId String

  type        String
  description String
  metadata    Json?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([createdById])
  @@map("task_activities")
}

// ─────────────────────────────────────────────────────────
// PRODUCT CATALOG MODELS
// ─────────────────────────────────────────────────────────

model Insurer {
  id String @id @default(uuid())

  name               String
  shortName          String?
  registrationNumber String?
  iraLicenseNumber   String?

  logoUrl String?

  address String?
  county  String?
  country String? @default("Kenya")
  phone   String?
  email   String?
  website String?

  bankName          String?
  bankBranch        String?
  bankAccountName   String?
  bankAccountNumber String?
  bankSwiftCode     String?

  iraClassifications InsuranceClass[]

  status String @default("ACTIVE")

  notes String?

  contacts              InsurerContact[]
  products              Product[]
  policies              Policy[]
  claims                Claim[]
  onboardingCases       OnboardingCase[]
  commissionRules       CommissionRule[]
  directInsurerPayments DirectInsurerPayment[]
  commissionEntries     CommissionEntry[]
  insurerRemittances    InsurerRemittance[]

  createdById String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  Invoice   Invoice[]

  @@index([status])
  @@index([iraLicenseNumber])
  @@map("insurers")
}

model InsurerContact {
  id        String @id @default(uuid())
  insurerId String

  name       String
  title      String?
  department String?
  email      String?
  phone      String?

  isPrimary Boolean @default(false)
  notes     String?

  insurer Insurer @relation(fields: [insurerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([insurerId])
  @@map("insurer_contacts")
}

model Product {
  id String @id @default(uuid())

  insurerId String
  insurer   Insurer @relation(fields: [insurerId], references: [id])

  code           String         @unique
  name           String
  insuranceClass InsuranceClass
  category       String
  subcategory    String?
  description    String?

  eligibleClientTypes ClientType[]

  minPremium    Decimal? @db.Decimal(15, 2)
  maxPremium    Decimal? @db.Decimal(15, 2)
