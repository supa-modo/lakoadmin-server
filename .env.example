# ─────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/lako_agency?schema=public"

# ─────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────
# Account Lockout
# ─────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ─────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────
# DigitalOcean Spaces / S3
# ─────────────────────────────────────────────────────────
SPACES_KEY=
SPACES_SECRET=
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
SPACES_BUCKET=lako-agency
SPACES_REGION=fra1

# ─────────────────────────────────────────────────────────
# SMTP (nodemailer)
# ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Lako Admin <noreply@lako.co.ke>"

# ─────────────────────────────────────────────────────────
# Africa's Talking (SMS)
# ─────────────────────────────────────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox

# ─────────────────────────────────────────────────────────
# Admin seed
# ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@lako.co.ke
ADMIN_PASSWORD=Admin@1234!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin

# ─────────────────────────────────────────────────────────
# Workers
# ─────────────────────────────────────────────────────────
ENABLE_WORKERS=false

# ─────────────────────────────────────────────────────────
# Frontend URL (for password reset links)
# ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
